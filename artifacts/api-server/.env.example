# API Server — local development environment
# Copy this file:
#   Windows:  copy artifacts\api-server\.env.example artifacts\api-server\.env
#   Mac/Linux: cp artifacts/api-server/.env.example artifacts/api-server/.env

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# You MUST replace this with a real connection string — the server will not
# start until DATABASE_URL points to a reachable database.
#
# Option A — Neon (free cloud, recommended — no local install needed):
#   Sign up at https://neon.tech → New Project → Connect → copy the string.
#   It looks like:
#   postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
# Option B — Local PostgreSQL (must be installed and running):
#   postgresql://postgres:YOURPASSWORD@localhost:5432/learnhub
#   (Run `CREATE DATABASE learnhub;` in psql first)
#
DATABASE_URL=REPLACE_WITH_YOUR_CONNECTION_STRING

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get these from your Clerk dashboard: https://dashboard.clerk.com → API Keys
# Must match VITE_CLERK_PUBLISHABLE_KEY in artifacts/learn/.env
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ── Clerk Webhook (optional for local dev, required for production) ────────────
# In Clerk dashboard → Webhooks → Add Endpoint
#   URL: https://your-api.onrender.com/api/webhooks/clerk
#   Events: user.created, user.updated, user.deleted
# Copy the "Signing Secret" shown after creating the endpoint.
# Without this, user sync still works lazily (on first API call) — but
# setting this enables instant sync the moment someone signs up.
# CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Frontend URL (required for production eSewa payment redirects) ─────────────
# Set this to your Vercel URL so eSewa redirects users back to the right place.
# Leave blank for local dev — defaults to http://localhost:3000
# FRONTEND_URL=https://your-app.vercel.app

# ── eSewa Payments (optional — sandbox works without these) ───────────────────
# Leave blank to use eSewa sandbox (test mode). Only needed for live payments.
# ESEWA_PRODUCT_CODE=YOUR_MERCHANT_CODE
# ESEWA_SECRET_KEY=YOUR_SECRET_KEY
# ESEWA_MONTHLY_PRICE=299
# ESEWA_YEARLY_PRICE=2399
# ESEWA_ENV=production
