# Frontend — local development environment
# Windows: copy artifacts\learn\.env.example artifacts\learn\.env
# Mac/Linux: cp artifacts/learn/.env.example artifacts/learn/.env

# ── Clerk Auth ───────────────────────────────────────────────────────────────
# Get this from https://dashboard.clerk.com → your app → API Keys
# Must match CLERK_PUBLISHABLE_KEY in artifacts/api-server/.env
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── API URL ───────────────────────────────────────────────────────────────────
# Points the frontend at your local API server
VITE_API_URL=http://localhost:8080

# ── Dev Server ────────────────────────────────────────────────────────────────
PORT=3000
BASE_PATH=/

# ── NOTE: VITE_CLERK_PROXY_URL ────────────────────────────────────────────────
# Do NOT set this for local development — Clerk's proxy only works with
# production keys (pk_live_...) on a deployed domain.
# Setting it locally with pk_test_ keys will crash the app with:
#   "Failed to load Clerk JS"
# Leave this line commented out unless you are configuring a custom production domain.
# VITE_CLERK_PROXY_URL=https://yourdomain.com/api/__clerk
